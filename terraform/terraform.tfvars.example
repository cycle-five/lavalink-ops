vultr_api_key = "your-vultr-api-key-here"
region        = "ewr"             # New Jersey (see: https://api.vultr.com/v2/regions)
plan          = "vc2-2c-4gb"      # 2 vCPU, 4GB RAM
repo_url      = "https://github.com/your-org/your-repo.git"  # Git repository to deploy from
admin_port    = 8080              # Port on which the admin/service UI will listen
