# =============================================================================
# lavalink-ops — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Lavalink ---
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_PORT=2333
LAVALINK_JAVA_OPTS=-Xmx512M
LAVALINK_CONTAINER_NAME=lavalink

# --- yt-cipher ---
# Random token for authenticating Lavalink -> yt-cipher requests.
# Must match remoteCipher.password in application.yml
CIPHER_API_TOKEN=change-me-cipher-token

# --- Admin Panel ---
ADMIN_PASSWORD=change-me-admin
ADMIN_SECRET_KEY=change-me-session-secret
ADMIN_PORT=8080

# --- PoToken Refresh ---
POT_REFRESH_ENABLED=true
POT_REFRESH_INTERVAL_HOURS=6
